# Copy to `.env` for local development only. Do not commit `.env` (it is gitignored).
# Process environment always overrides these values when both are set.

# Optional: set to 0/false/no/off to skip loading `.env` entirely.
# WISDOMIZE_LOAD_DOTENV=1

# Presentation LLM. Use placeholder values only in this example file.
# For Anthropic local dev, put the real key in `.env` or ignored `config/local_secrets.json`.
PRESENTATION_LLM_PROVIDER=anthropic
PRESENTATION_LLM_BASE_URL=https://api.anthropic.com/v1/messages
PRESENTATION_LLM_API_KEY=replace-with-local-dev-key
PRESENTATION_LLM_MODEL=claude-haiku-4-5
PRESENTATION_LLM_TIMEOUT_SECONDS=20

PRESENTATION_LLM_ENABLED=true
PRESENTATION_LLM_SHADOW=false
PRESENTATION_LLM_REPAIR_ENABLED=true
PRESENTATION_LLM_MAX_REPAIR_ATTEMPTS=1
