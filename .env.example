# Copy to `.env` for local development only. Do not commit `.env` (it is gitignored).
# Process environment always overrides these values when both are set.
# Safe placeholders only — never commit real secrets or personal credentials.

# Optional: set to 0/false/no/off to skip loading `.env` entirely.
# WISDOMIZE_LOAD_DOTENV=1

# --- Django / deployment (app.deploy.site_settings)
DJANGO_SECRET_KEY=replace-me-generate-a-long-random-string
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_SECURE_HSTS_SECONDS=2592000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_SECURE_HSTS_PRELOAD=false
DJANGO_STATIC_ROOT=/var/lib/wisdomize/static_collected

# Postgres in production — local dev omits DATABASE_URL for default SQLite path.
DATABASE_URL=postgres://REPLACE_USER:REPLACE_PASSWORD@REPLACE_HOST:5432/REPLACE_DBNAME
# Optional SQLite path override when DATABASE_URL is unset (usually local only).
DJANGO_SQLITE_PATH=
# Dangerous escape hatch: allow repo-local SQLite files when DATABASE_URL absent (staging only).
DJANGO_ALLOW_SQLITE_IN_PRODUCTION=false
DJANGO_DATABASE_CONN_MAX_AGE=600

# --- Product runtime / plans (Step 38A — see docs/runtime_config.md)
# WISDOMIZE_PLANS_JSON={"free":{"monthly_analysis_limit":5,"price_display":"₹0","label":"Free","enabled":true}}
# WISDOMIZE_PLANS_CONFIG_PATH=/path/to/plans.json
# WISDOMIZE_VERSE_MATCH_SCORE_THRESHOLD=6
# WISDOMIZE_MAX_MISSING_FACTS=6
# WISDOMIZE_FEEDBACK_COMMENT_MAX_LEN=500
# WISDOMIZE_DASHBOARD_HISTORY_PAGE_SIZE=20

# --- Email (verification / notifications)
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=smtp.placeholder.example.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_USE_TLS=true
DJANGO_EMAIL_HOST_USER=replace-me-smtp-username
DJANGO_EMAIL_HOST_PASSWORD=replace-me-smtp-password
DJANGO_DEFAULT_FROM_EMAIL=no-reply@yourdomain.com
DJANGO_EMAIL_VERIFICATION_REQUIRES_SMTP=false

# --- Google OAuth (optional login)
DJANGO_GOOGLE_OAUTH_CLIENT_ID=
DJANGO_GOOGLE_OAUTH_CLIENT_SECRET=

# Presentation LLM. Use placeholder values only in this example file.
# For Anthropic local dev, put the real key in `.env` or ignored `config/local_secrets.json`.
PRESENTATION_LLM_PROVIDER=anthropic
PRESENTATION_LLM_BASE_URL=https://api.anthropic.com/v1/messages
PRESENTATION_LLM_API_KEY=replace-with-local-dev-key
PRESENTATION_LLM_MODEL=claude-haiku-4-5
PRESENTATION_LLM_TIMEOUT_SECONDS=20

PRESENTATION_LLM_ENABLED=true
PRESENTATION_LLM_SHADOW=false
PRESENTATION_LLM_REPAIR_ENABLED=true
PRESENTATION_LLM_MAX_REPAIR_ATTEMPTS=1
